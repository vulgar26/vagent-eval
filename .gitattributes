# Normalize line endings: store everything as LF in the repo.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files: never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.gz binary
*.pdf binary
